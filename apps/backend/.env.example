APP_NAME=OneMoon API
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=onemoon
ALLOWED_ORIGINS=http://localhost:5173
LLM_PROVIDER=mock
LLM_MODEL=gpt-4.1-mini
# Set LLM_PROVIDER=openai plus either LLM_API_KEY or OPENAI_API_KEY for real API testing.
# The backend also accepts repo-root ONEMOON_* variables.
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_TIMEOUT_SECONDS=45
# Optional override for LAN dev. The default app config already allows common
# private-network frontend origins like http://192.168.x.x:5173.
# ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|192\.168(?:\.\d{1,3}){2})(?::\d+)?$
